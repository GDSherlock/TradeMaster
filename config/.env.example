# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/market_data
DEFAULT_EXCHANGE=binance_futures_um

# Auth/CORS
AUTH_ENABLED=false
API_TOKEN=dev-token
CORS_ALLOW_ORIGINS=http://localhost:8088

# API service
API_SERVICE_HOST=0.0.0.0
API_SERVICE_PORT=8000
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_BURST=20

# Pipeline service
PIPELINE_SERVICE_HOST=0.0.0.0
PIPELINE_SERVICE_PORT=9101
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
INTERVALS=1m,5m,15m,1h,4h,1d
BACKFILL_DAYS=365
BACKFILL_CHUNK_ROWS=100000
HF_DATASET=123olp/binance-futures-ohlcv-2018-2026
HF_CANDLES_FILE=candles_1m.csv.gz
WS_URL=wss://fstream.binance.com/stream
WS_RECONNECT_MAX_SECONDS=60
WS_FLUSH_SECONDS=3
REST_FALLBACK_INTERVAL_SECONDS=60
INDICATOR_SCHEDULE_SECONDS=60

# Signal service
SIGNAL_SERVICE_HOST=0.0.0.0
SIGNAL_SERVICE_PORT=8002
SIGNAL_SCHEDULE_SECONDS=30
SIGNAL_WS_POLL_SECONDS=1.0
SIGNAL_RATE_LIMIT_PER_MINUTE=120
SIGNAL_RATE_LIMIT_BURST=20

# Chat service
CHAT_SERVICE_HOST=0.0.0.0
CHAT_SERVICE_PORT=8001
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_MAX_CONCURRENCY_PER_IP=5
CHAT_MAX_INPUT_CHARS=2000
CHAT_MAX_TURNS=12
API_SERVICE_BASE_URL=http://localhost:8000
API_SERVICE_TOKEN=
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.2
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_CHARS=4000

# Dashboard
WEB_DASHBOARD_HOST=0.0.0.0
WEB_DASHBOARD_PORT=8088
