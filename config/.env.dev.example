# DEV-ONLY profile. DO NOT use in staging/prod.
# Local debug convenience settings.

# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/market_data
DEFAULT_EXCHANGE=binance_futures_um

# Auth/CORS (dev only)
AUTH_ENABLED=false
API_TOKEN=dev-token
CORS_ALLOW_ORIGINS=http://localhost:8088

# API service
API_SERVICE_HOST=0.0.0.0
API_SERVICE_PORT=8000
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_BURST=20

# Pipeline service
PIPELINE_SERVICE_HOST=0.0.0.0
PIPELINE_SERVICE_PORT=9101
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT
INTERVALS=1m,5m,15m,1h,4h,1d
BACKFILL_DAYS=365
BACKFILL_CHUNK_ROWS=100000
HF_DATASET=123olp/binance-futures-ohlcv-2018-2026
HF_CANDLES_FILE=candles_1m.csv.gz
WS_URL=wss://fstream.binance.com/stream
WS_RECONNECT_MAX_SECONDS=60
WS_FLUSH_SECONDS=3
REST_FALLBACK_INTERVAL_SECONDS=60
INDICATOR_SCHEDULE_SECONDS=60

# Signal service
SIGNAL_SERVICE_HOST=0.0.0.0
SIGNAL_SERVICE_PORT=8002
SIGNAL_SCHEDULE_SECONDS=30
SIGNAL_WS_POLL_SECONDS=1.0
SIGNAL_RATE_LIMIT_PER_MINUTE=120
SIGNAL_RATE_LIMIT_BURST=20

# ML validator service
ML_VALIDATOR_SERVICE_HOST=0.0.0.0
ML_VALIDATOR_SERVICE_PORT=8003
ML_VALIDATOR_RATE_LIMIT_PER_MINUTE=120
ML_VALIDATOR_RATE_LIMIT_BURST=20
ML_VALIDATE_LOOP_SECONDS=30
ML_VALIDATE_BATCH_SIZE=200
ML_TRAIN_LOOP_SECONDS=3600
ML_TRAIN_SCHEDULE_HOUR=2
ML_TRAIN_SCHEDULE_MINUTE=10
ML_TRAIN_TIMEZONE=Asia/Singapore
ML_MONITOR_LOOP_SECONDS=60
ML_RECALIBRATE_SCHEDULE_WEEKDAY=6
ML_RECALIBRATE_SCHEDULE_HOUR=2
ML_RECALIBRATE_SCHEDULE_MINUTE=40
ML_RECALIBRATE_LOOKBACK_DAYS=60
ML_MODEL_NAME=rsi_lr_calibrated
ML_MODEL_REGISTRY_DIR=
ML_DECISION_THRESHOLD=0.55
ML_TOP_FEATURES=6
ML_LOOKBACK_DAYS=180
ML_VAL_DAYS=30
ML_TEST_DAYS=14
ML_MIN_SAMPLES=200
ML_INTERVAL=1h
ML_HORIZON_BARS=6
ML_BARRIER_TP_ATR_MULT=1.0
ML_BARRIER_SL_ATR_MULT=1.0
ML_PROMOTE_MIN_PRECISION_GAIN=0.03
ML_PROMOTE_MAX_BRIER_DEGRADE=0.01
ML_COVERAGE_MIN=0.15
ML_COVERAGE_MAX=0.60
ML_DRIFT_CHECK_HOURS=6
ML_DRIFT_PSI_THRESHOLD=0.2
ML_DRIFT_LOOKBACK_HOURS=24
ML_DRIFT_SAMPLE_LIMIT=2000
ML_DRIFT_MIN_SAMPLES=150

# Chat service
CHAT_SERVICE_HOST=0.0.0.0
CHAT_SERVICE_PORT=8001
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_MAX_CONCURRENCY_PER_IP=5
CHAT_MAX_INPUT_CHARS=2000
CHAT_MAX_TURNS=12
API_SERVICE_BASE_URL=http://localhost:8000
API_SERVICE_TOKEN=dev-token
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.2
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_CHARS=4000

# Dashboard
WEB_DASHBOARD_HOST=0.0.0.0
WEB_DASHBOARD_PORT=8088
CHAT_SERVICE_BASE_URL=http://localhost:8001
